---
# Renders into Environment Credentials File; must match credential.schema.json per entry.
app-db-cred:
  type: external
  create: true
  secretStore: default-store
  remoteRefPath: "{{ current_env.cloud }}/{{ current_env.name }}/db"
  properties:
    - name: username
    - name: password
app-sidecar-token:
  type: external
  create: true
  secretStore: default-store
  remoteRefPath: "{{ current_env.cloud }}/{{ current_env.name }}/sidecar"
