# Registry Definition Template reference:
# https://github.com/Netcracker/qubership-envgene/blob/main/docs/envgene-objects.md#registry-definition-template

name: "registry-1"
credentialsId: "registry-cred"
mavenConfig:
  repositoryDomainName: "{{ regdefs.overrides.maven.RepositoryDomainName | default('maven.example.com') }}"
  targetSnapshot: "snapshot"
  targetStaging: "staging"
  targetRelease: "release"
dockerConfig:
  snapshotUri: "docker.example.com/snapshot"
  stagingUri: "docker.example.com/staging"
  releaseUri: "docker.example.com/release"
  groupUri: "docker.example.com/group"
  snapshotRepoName: "docker-snapshot"
  stagingRepoName: "docker-staging"
  releaseRepoName: "docker-release"
  groupName: "docker-group"
